# Copy to .env and fill in to enable GitLab-backed sign-in.
# docker-compose reads these automatically; .env is git-ignored.
#
# Create a GitLab OAuth application (User Settings > Applications, or an
# instance/group app) with:
#   - Redirect URI:  https://zed.dondish.me:8443/auth/gitlab/callback
#   - Scopes:        read_user
# then paste its Application ID / Secret below.

# GitLab instance (gitlab.com or your self-hosted URL)
GITLAB_URL=https://gitlab.com

# OAuth application credentials (leave empty to keep the username form)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Must exactly match the Redirect URI registered on the GitLab app.
GITLAB_REDIRECT_URI=https://zed.dondish.me:8443/auth/gitlab/callback

# Shared secret between this server and collab (also set for the collab service).
# INTERNAL_API_KEY=internal-api-key-secret
