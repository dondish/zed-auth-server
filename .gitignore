# Secrets — private keys, issued tokens, OAuth client secret. Never commit.
certs/
data/
.env
# Filled-in Kubernetes/OpenShift secret manifests (templates end in .example.yaml)
deploy/**/secrets.local.yaml
deploy/**/*.local.yaml

# Scraped release installers (large binaries; regenerate with scrape_releases.py)
releases/

# Scraped extension archives (regenerate with scrape_extensions.py)
extensions/
extensions.zip
*.zip

# Mirrored ACP registry agents (regenerate with scrape_acp_registry.py)
acp/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Build / runtime artifacts
build-collab.log
*.log
